# ─── PILL-X Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.

# ── PayPal ────────────────────────────────────────────────────────────────────
# Get from: https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET_HERE
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID_HERE
# PayPal account that receives all sale proceeds
NEXT_PUBLIC_PAYPAL_PAYEE_EMAIL=warddavis030-4@gmail.com

# ── Smart Contract ────────────────────────────────────────────────────────────
# Deployed contract address (filled after running npm run deploy:contracts)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# ── Metadata ──────────────────────────────────────────────────────────────────
# Absolute path to the pre-generated metadata/tokens/ directory
METADATA_DIR=/path/to/PILL-X/metadata/tokens

# Absolute path to metadata/serials.json
SERIALS_FILE=/path/to/PILL-X/metadata/serials.json

# ── Base URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://pill-x.com
# Internal base URL used for server-side API fetches (not exposed to client)
INTERNAL_API_BASE_URL=http://localhost:3000

# ── Blockchain RPC (for server-side minting) ─────────────────────────────────
ETHEREUM_RPC_URL=
POLYGON_RPC_URL=
BSC_RPC_URL=
AVALANCHE_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
BASE_RPC_URL=

# ── Deployer / minting wallet ─────────────────────────────────────────────────
# Private key of the wallet that will call mint() after PayPal payment confirmed
DEPLOYER_PRIVATE_KEY=

# ── Base metadata URI (must match what was passed to the constructor) ─────────
BASE_METADATA_URI=https://pill-x.com/api/metadata/

# ── Payment recipient wallet (receives all on-chain sale proceeds) ────────────
PAYMENT_RECIPIENT=

# ── Block explorer API keys (for contract verification) ───────────────────────
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=
BASESCAN_API_KEY=
